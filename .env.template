# Django
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500
CORS_ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500

# Superuser (created automatically on first start)
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=adminpassword

# Database (PostgreSQL)
DB_NAME=videoflix_db
DB_USER=videoflix_user
DB_PASSWORD=your-database-password
DB_HOST=db
DB_PORT=5432

# Redis
REDIS_HOST=redis
REDIS_LOCATION=redis://redis:6379/1
REDIS_PORT=6379
REDIS_DB=0

# Email
# Use 'django.core.mail.backends.console.EmailBackend' for local testing (prints to Docker logs)
# Use 'django.core.mail.backends.smtp.EmailBackend' for production
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=your-email-password
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
DEFAULT_FROM_EMAIL=noreply@videoflix.com

# URLs
# FRONTEND_URL: used in emails when DEBUG=False (production)
FRONTEND_URL=http://localhost:4200
# BACKEND_URL: used in activation emails when DEBUG=True (local testing)
BACKEND_URL=http://localhost:8000
